{
  "tasks": {
    "canvas": "deno run -A tools/cli-enhanced.ts canvas",
    "canvas-legacy": "deno run -A tools/cli.ts canvas",
    "canvas-server": "deno run -A tools/canvas-server.ts",
    "self-managing-canvas": "deno run -A tools/self-managing-canvas-server.ts",
    "validate": "deno run -A tools/guardian.ts",
    "validate-integrated": "deno run -A tools/integrated-guardian.ts validate",
    "activity": "deno run -A tools/integrated-guardian.ts activity",
    "lifecycle": "deno run -A tools/integrated-guardian.ts lifecycle",
    "check-path": "deno run -A tools/integrated-guardian.ts check-path",
    "prepare-hooks": "deno run -A tools/tasks.ts install-hooks",
    "render-canvas": "deno run -A tools/canvas-renderer.ts",
    "render-enhanced": "deno run -A tools/canvas-render.ts",
    "render-all": "deno run -A tools/canvas-renderer.ts --all",
    "render-all-enhanced": "deno run -A tools/canvas-render.ts --all",
    "jsoncanvas-demo": "deno run -A tools/jsoncanvas-demo.ts",
    "fsm": "deno run -A tools/fsm-manager.ts",
    "validate-config": "deno run -A tools/schema-validator.ts",
    "test": "deno test --allow-all --no-check tests/",
    "test-modules": "deno test --allow-all modules/",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": ["tools/", "tests/", "modules/"],
    "exclude": ["tools/canvas-editor.html"]
  },
  "lint": {
    "include": ["tools/", "tests/", "modules/"],
    "exclude": ["tools/canvas-editor.html"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true
  }
}